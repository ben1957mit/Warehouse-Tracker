import sqlite3
from datetime import datetime, timedelta

DB_NAME = "warehouse_productivity.db"

# -----------------------------
# Database setup
# -----------------------------

def init_db():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()

    # Employees
    c.execute("""
        CREATE TABLE IF NOT EXISTS employees (
            id INTEGER PRIMARY KEY,
            name TEXT NOT NULL
        )
    """)

    # Shifts (sign in / sign out)
    c.execute("""
        CREATE TABLE IF NOT EXISTS shifts (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            employee_id INTEGER NOT NULL,
            shift_date TEXT NOT NULL,
            start_time TEXT NOT NULL,
            end_time TEXT,
            FOREIGN KEY(employee_id) REFERENCES employees(id)
        )
    """)

    # Activities (transactions)
    c.execute("""
        CREATE TABLE IF NOT EXISTS activities (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            employee_id INTEGER NOT NULL,
            shift_id INTEGER NOT NULL,
            timestamp TEXT NOT NULL,
            activity_type TEXT NOT NULL,
            units INTEGER NOT NULL,
            product_code TEXT,
            FOREIGN KEY(employee_id) REFERENCES employees(id),
            FOREIGN KEY(shift_id) REFERENCES shifts(id)
        )
    """)

    # Safety events
    c.execute("""
        CREATE TABLE IF NOT EXISTS safety_events (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            employee_id INTEGER,
            shift_id INTEGER,
            timestamp TEXT NOT NULL,
            description TEXT NOT NULL,
            severity TEXT,
            FOREIGN KEY(employee_id) REFERENCES employees(id),
            FOREIGN KEY(shift_id) REFERENCES shifts(id)
        )
    """)

    # Quality events
    c.execute("""
        CREATE TABLE IF NOT EXISTS quality_events (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            employee_id INTEGER,
            shift_id INTEGER,
            timestamp TEXT NOT NULL,
            issue_type TEXT NOT NULL,  -- mispick, damage, wrong product, loading error, putaway error
            description TEXT,
            FOREIGN KEY(employee_id) REFERENCES employees(id),
            FOREIGN KEY(shift_id) REFERENCES shifts(id)
        )
    """)

    conn.commit()
    conn.close()


# -----------------------------
# Employee management
# -----------------------------

def add_employee(emp_id: int, name: str):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO employees (id, name) VALUES (?, ?)", (emp_id, name))
    conn.commit()
    conn.close()


# -----------------------------
# Shift management
# -----------------------------

def start_shift(employee_id: int) -> int:
    """Employee signs in at start of shift. Returns shift_id."""
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.now()
    shift_date = now.date().isoformat()
    c.execute("""
        INSERT INTO shifts (employee_id, shift_date, start_time)
        VALUES (?, ?, ?)
    """, (employee_id, shift_date, now.isoformat()))
    shift_id = c.lastrowid
    conn.commit()
    conn.close()
    return shift_id


def end_shift(shift_id: int):
    """Employee signs out at end of shift."""
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.now().isoformat()
    c.execute("UPDATE shifts SET end_time = ? WHERE id = ?", (now, shift_id))
    conn.commit()
    conn.close()


# -----------------------------
# Activity logging
# -----------------------------

VALID_ACTIVITIES = [
    "case_picking",
    "pallet_picking",
    "case_putaway",
    "pallet_putaway",
    "loading_trucks",
    "unloading_trucks"
]

def log_activity(employee_id: int, shift_id: int, activity_type: str, units: int, product_code: str = None):
    """
    Log a transaction. 'units' is the industrial engineering standard unit
    (e.g., cases, pallets, lines, etc.).
    """
    if activity_type not in VALID_ACTIVITIES:
        raise ValueError(f"Invalid activity_type: {activity_type}")

    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.now().isoformat()
    c.execute("""
        INSERT INTO activities (employee_id, shift_id, timestamp, activity_type, units, product_code)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (employee_id, shift_id, now, activity_type, units, product_code))
    conn.commit()
    conn.close()


# -----------------------------
# Safety & Quality logging
# -----------------------------

def log_safety_event(employee_id: int, shift_id: int, description: str, severity: str = None):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.now().isoformat()
    c.execute("""
