def log_quality_event(employee_id: int, shift_id: int, issue_type: str, description: str = None):
    """
    issue_type examples: 'mispick', 'damage', 'wrong_product', 'loading_error', 'putaway_error'
    """
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.now().isoformat()
    c.execute("""
        INSERT INTO quality_events (employee_id, shift_id, timestamp, issue_type, description)
        VALUES (?, ?, ?, ?, ?)
    """, (employee_id, shift_id, now, issue_type, description))
    conn.commit()
    conn.close()


# -----------------------------
# Productivity calculations
# -----------------------------

def _get_shift_duration_hours(shift_row) -> float:
    start = datetime.fromisoformat(shift_row[3])
    end_str = shift_row[4]
    if not end_str:
        end = datetime.now()
    else:
        end = datetime.fromisoformat(end_str)
    duration = end - start
    return max(duration.total_seconds() / 3600.0, 0.0001)  # avoid divide by zero


def get_employee_productivity(employee_id: int, shift_date: str = None):
    """
    Returns units per hour by activity for a given employee.
    If shift_date is None, uses today's date.
    """
    if shift_date is None:
        shift_date = datetime.now().date().isoformat()

    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()

    # Get shifts for that date
    c.execute("""
        SELECT id, employee_id, shift_date, start_time, end_time
        FROM shifts
        WHERE employee_id = ? AND shift_date = ?
    """, (employee_id, shift_date))
    shifts = c.fetchall()

    productivity = {}  # {activity_type: {"units": x, "hours": y, "uph": z}}

    for shift in shifts:
        shift_id = shift[0]
        duration_hours = _get_shift_duration_hours(shift)

        c.execute("""
            SELECT activity_type, SUM(units)
            FROM activities
            WHERE employee_id = ? AND shift_id = ?
            GROUP BY activity_type
        """, (employee_id, shift_id))
        rows = c.fetchall()

        for activity_type, total_units in rows:
            if activity_type not in productivity:
                productivity[activity_type] = {"units": 0, "hours": 0.0}
            productivity[activity_type]["units"] += total_units
            productivity[activity_type]["hours"] += duration_hours

    # Calculate units per hour
    for activity_type, data in productivity.items():
        data["uph"] = data["units"] / data["hours"] if data["hours"] > 0 else 0.0

    conn.close()
    return productivity


# -----------------------------
# Dashboard (text-based)
# -----------------------------

def dashboard_for_day(shift_date: str = None):
    """
    Simple console dashboard for supervisors/managers:
    - Productivity by employee and activity
    - Safety events
    - Quality events
    """
    if shift_date is None:
        shift_date = datetime.now().date().isoformat()

    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()

    print(f"\n=== DASHBOARD FOR {shift_date} ===")

    # Employees signed in that day
    c.execute("""
        SELECT DISTINCT e.id, e.name
        FROM employees e
        JOIN shifts s ON e.id = s.employee_id
        WHERE s.shift_date = ?
    """, (shift_date,))
    employees = c.fetchall()

    # Productivity section
    print("\n--- Productivity (Units per Hour by Activity) ---")
    for emp_id, name in employees:
        prod = get_employee_productivity(emp_id, shift_date)
        print(f"\nEmployee {emp_id} - {name}")
        if not prod:
            print("  No activity logged.")
            continue
        for activity_type, data in prod.items():
            print(f"  {activity_type}: Units={data['units']:.2f}, Hours={data['hours']:.2f}, UPH={data['uph']:.2f}")

    # Safety section
    print("\n--- Safety Events ---")
    c.execute("""
        SELECT se.timestamp, e.name, se.description, se.severity
        FROM safety_events se
        LEFT JOIN employees e ON se.employee_id = e.id
        LEFT JOIN shifts s ON se.shift_id = s.id
        WHERE s.shift_date = ?
    """, (shift_date,))
    safety_rows = c.fetchall()
    if not safety_rows:
        print("  No safety events.")
    else:
        for ts, name, desc, sev in safety_rows:
            print(f"  [{ts}] Employee={name or 'N/A'} Severity={sev or 'N/A'} Desc={desc}")

    # Quality section
    print("\n--- Quality Events ---")
    c.execute("""
        SELECT qe.timestamp, e.name, qe.issue_type, qe.description
        FROM quality_events qe
        LEFT JOIN employees e ON qe.employee_id = e.id
        LEFT JOIN shifts s ON qe.shift_id = s.id
        WHERE s.shift_date = ?
    """, (shift_date,))
    quality_rows = c.fetchall()
    if not quality_rows:
        print("  No quality events.")
    else:
        for ts, name, issue_type, desc in quality_rows:
            print(f"  [{ts}] Employee={name or 'N/A'} Issue={issue_type} Desc={desc or ''}")

    conn.close()


# -----------------------------
# Example usage / CLI stub
# -----------------------------

def main():
    init_db()

    # Example: create employees 1–3
    add_employee(1, "Alice")
    add_employee(2, "Bob")
    add_employee(3, "Carlos")

    # Start shifts
    shift1 = start_shift(1)
    shift2 = start_shift(2)

    # Log activities (these would normally be triggered by scanner events)
    log_activity(1, shift1, "case_picking", 120, product_code="CASE123")
    log_activity(1, shift1, "pallet_picking", 15, product_code="PALLET45")
    log_activity(2, shift2, "loading_trucks", 80, product_code="LOAD789")

    # Safety & Quality examples
    log_safety_event(1, shift1, "Minor slip in aisle 3", severity="Minor")
    log_quality_event(2, shift2, "mispick", "Wrong SKU loaded on truck 12")

    # End shifts
    end_shift(shift1)
    end_shift(shift2)

    # Show dashboard
    dashboard_for_day()

if __name__ == "__main__":
    main()
